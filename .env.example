DATABASE_URL="postgresql://hayat_user:CHANGE_ME@postgres:5432/hayat_db?schema=public"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
PORT="3000"

# POS AYARLARI (demo, vakifkatilim veya paytr)
POS_PROVIDER="demo"

# Vakif Katilim Sanal POS
# common_page: kart bilgileri bankanin Guvenli Odeme Sayfasinda alinir.
# api_3d: kart bilgileri siteden alinip 3D API akisi baslatilir.
VAKIF_POS_MODE="common_page"
VAKIF_POS_COMMON_PAYMENT_ENDPOINT="https://boa.vakifkatilim.com.tr/VirtualPOS.Gateway/CommonPaymentPage/CommonPaymentPage"
VAKIF_POS_3D_PAY_ENDPOINT="https://boa.vakifkatilim.com.tr/VirtualPOS.Gateway/Home/ThreeDModelPayGate"
VAKIF_POS_3D_PROVISION_ENDPOINT="https://boa.vakifkatilim.com.tr/VirtualPOS.Gateway/Home/ThreeDModelProvisionGate"
VAKIF_POS_MERCHANT_ID=""
VAKIF_POS_CUSTOMER_ID=""
VAKIF_POS_USERNAME=""
VAKIF_POS_HASH_PASSWORD=""
VAKIF_POS_CURRENCY_CODE="0949"

# Hash sirasi:
# merchantId + merchantOrderId + amount + okUrl + failUrl + userName + hashPassword
VAKIF_POS_HASH_FIELDS="merchantId,merchantOrderId,amount,okUrl,failUrl,userName,hashPassword"
VAKIF_POS_HASH_SEPARATOR=""

PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""

# SMS AYARLARI (demo veya netgsm)
SMS_PROVIDER="demo"
NETGSM_USER=""
NETGSM_PASS=""
NETGSM_HEADER=""
